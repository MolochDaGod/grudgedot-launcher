# ==============================================
# GDEVELOP ASSISTANT — Grudge Studio Environment
# ==============================================
# Copy to .env and fill in your values. Never commit .env.
#
# Architecture: Auth proxied to VPS grudge-id service (id.grudge-studio.com).
# Game data from VPS game-api (api.grudge-studio.com).

# ══════════════════════════════════════════════
# CORE — Required for the app to function
# ══════════════════════════════════════════════

# Database — VPS MySQL via grudge-studio-backend (optional for local dev)
# For production, auth is handled by id.grudge-studio.com, game data by api.grudge-studio.com
DATABASE_URL=

# JWT signing secret — used by grudgeAuth.ts and grudgeJwt.ts
# Must match across all Grudge Studio apps sharing the same accounts table
SESSION_SECRET=your-session-secret-here

# Server
NODE_ENV=development
PORT=5000

# Admin (for admin-only API routes)
ADMIN_PASSWORD=

# ══════════════════════════════════════════════
# AI PROVIDERS — Powers chat, asset tagging, generation
# ══════════════════════════════════════════════

# xAI Grok — primary AI for game dev chat + asset descriptions
# Used by: vercelApp.ts (chat), asset-tagger.ts (AI descriptions)
XAI_API_KEY=

# OpenAI — sprite generation, AI personality, fallback chat
OPENAI_API_KEY=

# Meshy 3D — 3D asset generation (text-to-3d, retexture)
# Used by: vercelApp.ts + routes.ts (meshy proxy endpoints)
MESHY_API_KEY=

# Vidu — image-to-video cutscene generation
VIDU_API_KEY=

# ══════════════════════════════════════════════
# CROSSMINT — Solana wallet + cNFT minting
# ══════════════════════════════════════════════
# Characters and home islands are minted as Solana cNFTs via Crossmint.
# Custodial wallets are auto-created for new accounts in grudgeAuth.ts.
#
# Collection IDs (shared across all Grudge games):
#   Parent collection:    5061318d-ff65-4893-ac4b-9b28efb18ace
#   Character generation: a9bb2c8d-1350-4413-aec7-5ba1f6888511
#   Home Island:          18d0e641-8713-4d5b-9a1d-ba67c516a3ce

CROSSMINT_SERVER_API_KEY=
CROSSMINT_SECRET_KEY=
CROSSMINT_PROJECT_ID=
CROSSMINT_CLIENT_KEY=
CROSSMINT_COLLECTION_ID=a9bb2c8d-1350-4413-aec7-5ba1f6888511
CROSSMINT_ISLAND_CNFT=18d0e641-8713-4d5b-9a1d-ba67c516a3ce
CROSSMINT_USE_STAGING=false

# ══════════════════════════════════════════════
# BLOCKCHAIN / SOLANA
# ══════════════════════════════════════════════

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
AI_AGENT_SOL_ADDRESS=
GBUX_TOKEN_ADDRESS=

# ══════════════════════════════════════════════
# GAME SERVICES — External Grudge Studio services
# ══════════════════════════════════════════════

# Grudge Studio Game API (VPS — Coolify/Docker + Traefik)
GRUDACHAIN_URL=https://api.grudge-studio.com
GAME_API_GRUDA=https://api.grudge-studio.com

# Warlord Crafting Suite
WCS_URL=https://warlord-crafting-suite.vercel.app

# ══════════════════════════════════════════════
# GOOGLE OAUTH
# ══════════════════════════════════════════════
# Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: https://gdevelop-assistant.vercel.app/api/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══════════════════════════════════════════════
# DISCORD OAUTH
# ══════════════════════════════════════════════

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ══════════════════════════════════════════════
# GITHUB OAUTH
# ══════════════════════════════════════════════
# GitHub Developer Settings → OAuth Apps
# Authorized callback URL: https://gdevelop-assistant.vercel.app/api/auth/github/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ══════════════════════════════════════════════
# GRUDGE BACKEND (cross-service auth)
# ══════════════════════════════════════════════
# grudge-id service URL — used for cross-verifying tokens issued by grudge-backend

GRUDGE_BACKEND_URL=https://id.grudge-studio.com

# ══════════════════════════════════════════════
# CLIENT-SIDE (VITE_ prefix — exposed to browser)
# ══════════════════════════════════════════════

# Discord OAuth client ID (same value as DISCORD_CLIENT_ID)
VITE_DISCORD_CLIENT_ID=

# Crossmint public key (same value as CROSSMINT_CLIENT_KEY)
VITE_CROSSMINT_CLIENT_KEY=

# Colyseus multiplayer server (game lobby websocket)
VITE_COLYSEUS_WS_URL=ws://localhost:2567

# AI Worker toggle (enables client-side AI capture)
VITE_ENABLE_AI_WORKER=false

# Colyseus lobby toggle (switches lobby from Socket.IO to Colyseus)
VITE_USE_COLYSEUS=false

# ══════════════════════════════════════════════
# PUTER CLOUD (client-side KV/FS storage)
# ══════════════════════════════════════════════
# Puter SDK loads via CDN on the client — no server config needed.
# Neon PostgreSQL remains the server-side source of truth.

PUTER_APP_ID=

# ══════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════

ENABLE_AI_FEATURES=true
ENABLE_NFT_FEATURES=false
ENABLE_GOOGLE_SHEETS=false
ENABLE_PUTER_CLOUD=false
