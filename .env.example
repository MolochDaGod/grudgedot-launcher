# ==============================================
# GDEVELOP ASSISTANT - Grudge Studio Environment
# ==============================================
# Copy to .env and fill in your values. Never commit .env.
#
# CRITICAL: SESSION_SECRET MUST match auth-gateway-flax.vercel.app.
# Both apps sign/verify JWTs with this value. If they differ, local
# JWT verification fails and every request falls back to a remote
# call to the gateway (slower, network-dependent).

# Server Configuration
NODE_ENV=development
PORT=5000

# Database (Neon PostgreSQL - shared with Warlord-Crafting-Suite)
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require
PGDATABASE=neondb
PGHOST=your-neon-host.neon.tech
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password

# ==============================================
# AUTHENTICATION (Grudge Auth Gateway)
# ==============================================
# All auth (login, register, guest, OAuth, wallet, phone) is proxied
# to the auth gateway. The gateway owns the accounts table and issues
# JWTs. GDevelop verifies them locally with SESSION_SECRET, falling
# back to remote /api/verify if the secret doesn't match.
#
# Supported flows: password, guest, Puter SSO, Discord OAuth,
# GitHub OAuth, Google OAuth, phone/SMS, Solana wallet.

# JWT signing secret — MUST match the auth-gateway deployment
SESSION_SECRET=change-this-MUST-match-auth-gateway

# Auth gateway base URL (default: https://auth-gateway-flax.vercel.app)
AUTH_GATEWAY_URL=https://auth-gateway-flax.vercel.app

# Admin password (for admin-only routes)
ADMIN_PASSWORD=

# ==============================================
# DISCORD OAUTH
# ==============================================
# MUST use the same Discord application as auth-gateway & WCS.
# The gateway handles the OAuth callback; GGE just proxies the request.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
VITE_DISCORD_CLIENT_ID=  # Same as DISCORD_CLIENT_ID (for frontend)

# ==============================================
# AI PROVIDERS
# ==============================================

# X.AI Grok (Game dev assistant chat — 5 req/min limit)
XAI_API_KEY=

# OpenAI (sprite generation, AI personality, fallback chat)
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=  # Alternative env var name

# AI Integration URLs (local modelfarm proxy — dev only)
AI_INTEGRATIONS_OPENAI_BASE_URL=http://localhost:1106/modelfarm/openai
AI_INTEGRATIONS_GEMINI_BASE_URL=http://localhost:1106/modelfarm/gemini

# Meshy 3D (3D asset generation)
MESHY_API_KEY=

# ==============================================
# CROSSMINT — CNFT CHARACTER & ISLAND OWNERSHIP
# ==============================================
# Characters and home islands are minted as Solana cNFTs via Crossmint.
# Reference impl: Grudge-Builder/server/spriteGeneration/services/crossmintWallet.ts
#
# Collection IDs (shared across all Grudge games):
#   Parent collection:      5061318d-ff65-4893-ac4b-9b28efb18ace
#   Character generation:   a9bb2c8d-1350-4413-aec7-5ba1f6888511
#   Home Island:            18d0e641-8713-4d5b-9a1d-ba67c516a3ce

CROSSMINT_SERVER_API_KEY=  # Required: server-side API key for minting & wallets
CROSSMINT_SECRET_KEY=      # Alternative name (crossmintWallet.ts checks both)
CROSSMINT_PROJECT_ID=      # Crossmint project ID
CROSSMINT_CLIENT_KEY=      # Public client key (also set as VITE_CROSSMINT_CLIENT_KEY)
CROSSMINT_COLLECTION_ID=a9bb2c8d-1350-4413-aec7-5ba1f6888511  # Character cNFT collection
CROSSMINT_ISLAND_CNFT=18d0e641-8713-4d5b-9a1d-ba67c516a3ce    # Island cNFT template
CROSSMINT_USE_STAGING=false  # Set "true" for Crossmint staging API

# ==============================================
# BLOCKCHAIN / SOLANA
# ==============================================

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
AI_AGENT_SOL_ADDRESS=       # Optional: AI agent wallet for GbuX rewards
GBUX_TOKEN_ADDRESS=         # Optional: GbuX SPL token mint address

# ==============================================
# CLIENT-SIDE STORAGE (Puter Cloud)
# ==============================================
# Puter KV/FS handles client-side caching, saves, and file uploads.
# No server config needed — Puter SDK loads via CDN on the client.
# Neon PostgreSQL remains the server-side source of truth.

PUTER_APP_ID=              # Optional: branded Puter integration

# ==============================================
# GRUDA WARS / GRUDACHAIN
# ==============================================

# GRUDACHAIN AI Node System — Railway production deployment
GRUDACHAIN_URL=https://gruda-legion-production.up.railway.app

# Grudge Studio IDE Integration (for external game/IDE sync)
GAME_API_GRUDA=https://gruda-legion-production.up.railway.app

# Warlord Crafting Suite (dungeon, heroes, crafting)
WCS_URL=https://warlord-crafting-suite.vercel.app

# ==============================================
# VIDEO GENERATION (Vidu / Cutscener)
# ==============================================

# Vidu API — image-to-video cutscene generation
VIDU_API_KEY=

# ==============================================
# FEATURE FLAGS
# ==============================================

ENABLE_AI_FEATURES=true     # AI personality, sprite gen, chat
ENABLE_NFT_FEATURES=false   # Crossmint cNFT minting
ENABLE_GOOGLE_SHEETS=false  # Google Sheets data sync
ENABLE_PUTER_CLOUD=false    # Puter cloud storage features
