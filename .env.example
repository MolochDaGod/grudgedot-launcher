# ════════════════════════════════════════════════════════════════
# GRUDGE STUDIO — Frontend Environment Variables
# Copy to .env.local in your frontend project
# ALL frontends use the SAME URLs — no direct DB connections
# ════════════════════════════════════════════════════════════════

# Auth (login, register, OAuth, JWT)
VITE_AUTH_URL=https://id.grudge-studio.com

# Game API (economy, crafting, combat, islands, missions, crews, PvP)
VITE_API_URL=https://api.grudge-studio.com

# Account API (profiles, social, achievements)
VITE_ACCOUNT_URL=https://account.grudge-studio.com

# WebSocket (real-time: /game, /crew, /global, /pvp)
VITE_WS_URL=wss://ws.grudge-studio.com

# Launcher API (patch manifest, version gating)
VITE_LAUNCHER_URL=https://launcher.grudge-studio.com

# Assets CDN (textures, models, audio, sprites)
VITE_ASSETS_URL=https://assets.grudge-studio.com

# Static game data (weapons, armor, races, classes, factions)
VITE_OBJECTSTORE_URL=https://molochdagod.github.io/ObjectStore/api/v1

# ════════════════════════════════════════════════════════════════
# DO NOT ADD:
# - DATABASE_URL (never connect frontends to DB directly)
# - NEON_DATABASE_URL (removed — MySQL on VPS is the only DB)
# - SUPABASE_URL / SUPABASE_KEY (removed — not used)
# - Any API keys (secrets stay on the backend)
# ════════════════════════════════════════════════════════════════
