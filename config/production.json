{
  "services": {
    "aiAgents": {
      "maxAgents": 1000
    },
    "gameServer": {
      "maxPlayers": 500,
      "maxRooms": 200
    }
  },
  "security": {
    "rateLimit": {
      "enabled": true,
      "windowMs": 900000,
      "maxRequests": 1000
    },
    "cors": {
      "origins": [
        "https://gdevelop-assistant.vercel.app",
        "https://gdevelop-assistant-git-main-grudgenexus.vercel.app",
        "https://*.vercel.app",
        "https://*.grudge-studio.com"
      ]
    }
  },
  "logging": {
    "level": "warn",
    "destination": "file"
  }
}
